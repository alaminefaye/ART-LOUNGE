# Évite que le navigateur / un proxy garde une vieille version de l’app Flutter
# (main.dart.js garde le même nom à chaque build).
<IfModule mod_headers.c>
  <FilesMatch "^(index\.html|flutter_bootstrap\.js|flutter\.js|main\.dart\.js|flutter_service_worker\.js)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
